# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
ALPACA_API_KEY=your_key_here
ALPACA_SECRET_KEY=your_key_here
FINNHUB_API_KEY=your_key_here
PAPER_TRADING=true

# ── Secondary market data (at least one recommended) ──────────────────────────
# Massive.com — primary provider (verify endpoint at https://massive.com/docs)
MASSIVE_API_KEY=

# Polygon.io — fallback provider (https://polygon.io)
POLYGON_API_KEY=

# Which provider to prefer: "massive" or "polygon"
PREFERRED_PROVIDER=polygon

# ── Optional news feed ────────────────────────────────────────────────────────
# Benzinga Pro API — fast catalyst feed alongside Finnhub (paid, https://benzinga.com)
BENZINGA_API_KEY=
